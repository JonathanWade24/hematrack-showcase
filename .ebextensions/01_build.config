files:
  "/opt/elasticbeanstalk/hooks/appdeploy/pre/50npm.sh":
    mode: "000755"
    owner: root
    group: root
    content: |
      #!/bin/bash
      cd /var/app/staging
      
      # Install dev dependencies
      npm ci --include=dev
      
      # Build the application
      npm run build
      
      # Log the completion
      echo "Next.js application built successfully" 